model User {
  id         String   @id @default(uuid())
  username   String   @unique
  email      String   @unique
  password   String
  userRoleId Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  userRole UserRole @relation(fields: [userRoleId], references: [id])

  @@map("users")
}
