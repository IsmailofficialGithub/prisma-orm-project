model Player {
  id                       String    @id @default(uuid())
  username                 String    @unique
  email                    String    @unique
  google_id                String?   @unique // Google OAuth sub field - unique identifier
  walletIds                String[]
  password                 String
  heroId                   Int?      @default(1)
  factionId                Int       @default(1)
  totalXp                  Int       @default(0)
  seasonXp                 Int       @default(0)
  matchesPlayed            Int       @default(0)
  matchesWon               Int       @default(0)
  winStreak                Int       @default(0)
  loginStreakDays          Int       @default(0)
  lastLoginDate            DateTime?
  topCards                 Int[]     @default([])
  common_lootbox_opened    Int       @default(0) @db.Integer
  rare_lootbox_opened      Int       @default(0) @db.Integer
  legendary_lootbox_opened Int       @default(0) @db.Integer
  common_pity_counter      Int       @default(0) @db.Integer
  rare_pity_counter        Int       @default(0) @db.Integer
  legendary_pity_counter   Int       @default(0) @db.Integer
  free_crystal_claimed     Boolean   @default(false)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  // Relations
  hero                Hero?                   @relation(fields: [heroId], references: [id])
  faction             Faction                 @relation("PlayerFaction", fields: [factionId], references: [id])
  wallets             PlayerWallet[]          @relation("PlayerWallets")
  currenciesOwned     Currency[]              @relation("CurrencyOwner")
  currenciesModified  Currency[]              @relation("CurrencyModifier")
  decksOwned          Deck[]                  @relation("DeckOwner")
  decksModified       Deck[]                  @relation("DeckModifier")
  deckCardsModified   DeckCard[]              @relation("DeckCardModifier")
  inventoriesOwned    PlayerInventory[]       @relation("PlayerInventoryOwner")
  inventoriesModified PlayerInventory[]       @relation("PlayerInventoryModifier")
  deckCardsOwned      DeckCard[]              @relation("DeckCardOwner")
  ownedCards          PlayerCard[]            @relation("CardOwner")
  modifiedCards       PlayerCard[]            @relation("PlayerCardModifier")
  CardType            CardType[]
  Stage               Stage[]
  Card                Card[]
  CurrencyType        CurrencyType[]
  ranks               Rank[]
  Faction             Faction[]
  Order               Order[]
  DeckCard            DeckCard[]
  matchPlayerDecks    MatchPlayerDeck[]
  currentRounds       MatchRound[]
  roundEnergies       MatchRoundEnergy[]
  roundActions        MatchRoundAction[]
  matchPreparations   MatchPreparation[]      @relation("MatchPreparations")
  leaderboard         Leaderboard?            @relation("PlayerLeaderboard")
  xpGains             PlayerXpGains[]         @relation("PlayerXpGains")
  missionProgress     PlayerMissionProgress[] @relation("PlayerMissions")
  rewardGrants    RewardGrant[]       @relation("PlayerRewardGrants")
  ledgerEntries   PlayerLedgerEntry[] @relation("PlayerLedgerEntries")
  @@map("players")
}

model PlayerCard {
  id                       String    @id @unique @default(uuid())
  playerId                 String    @db.VarChar(36)
  cardId                   Int       @db.Integer
  acquiredAt               DateTime  @default(now()) @db.Timestamptz(6)
  card_acquisition_type_id Int       @db.Integer
  isMinted                 Boolean   @default(false) @db.Boolean
  total_damage_taken       Int       @default(0) @db.Integer
  total_damage_done        Int       @default(0) @db.Integer
  total_wins               Int       @default(0) @db.Integer
  is_archived              Boolean   @default(false) @db.Boolean
  games_played             Int       @default(0) @db.Integer
  total_heals_cast         Int       @default(0) @db.Integer
  cards_destroyed          Int       @default(0) @db.Integer
  deaths                   Int       @default(0) @db.Integer
  last_match_at            DateTime? @db.Timestamptz(6)
  modifiedById             String?   @db.VarChar(36)
  createdAt                DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime  @updatedAt @db.Timestamptz(6)

  // Relations
  player              Player              @relation("CardOwner", fields: [playerId], references: [id])
  card                Card                @relation(fields: [cardId], references: [id])
  cardAcquisitionType CardAcquisitionType @relation(fields: [card_acquisition_type_id], references: [id])
  modifiedBy          Player?             @relation("PlayerCardModifier", fields: [modifiedById], references: [id])
  deckCards           DeckCard[]

  @@map("player_cards")
}

model PlayerWallet {
  id        String   @id @default(uuid())
  address   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  players Player[] @relation("PlayerWallets")

  @@map("player_wallets")
}

model PlayerXpGains {
  id        String   @id @default(uuid())
  playerId  String
  xpAmount  Int
  createdAt DateTime @default(now())

  // Relations
  player Player @relation("PlayerXpGains", fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_xp_gains")
}

model PlayerSession {
  id                 String    @id @default(uuid()) @db.VarChar(36)
  player_id          String?   @db.VarChar(36)
  socket_id          String    @unique @db.VarChar(64)
  session_started_at DateTime? @db.Timestamptz(6)
  session_ended_at   DateTime? @db.Timestamptz(6)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  updated_at         DateTime  @updatedAt @db.Timestamptz(6)

  @@map("player_sessions")
}
