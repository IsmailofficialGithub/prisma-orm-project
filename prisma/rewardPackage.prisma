// Package version lifecycle states
model RewardPackageStatus {
  id         String   @id @default(uuid()) @db.Uuid
  code       String   @unique @db.VarChar(50)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  versions   RewardPackageVersion[]
  @@map("reward_package_status")
}

// Package definition (logical container for rewards)
model RewardPackage {
  id           String   @id @default(uuid()) @db.Uuid
  code         String   @unique @db.VarChar(100)
  display_name String   @db.VarChar(255)
  description  String?
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  versions     RewardPackageVersion[]
  missions     Mission[]
  @@map("reward_package")
}

// Concrete versions of a package
model RewardPackageVersion {
  id           String    @id @default(uuid()) @db.Uuid
  package_id   String    @db.Uuid
  status_id    String    @db.Uuid
  version      Int       @default(1)
  valid_from   DateTime?
  valid_to     DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  package      RewardPackage       @relation(fields: [package_id], references: [id])
  status       RewardPackageStatus @relation(fields: [status_id], references: [id])
  lines        RewardPackageLine[]
  choice_groups RewardChoiceGroup[]
  @@unique([package_id, version])
  @@map("reward_package_version")
}

// Individual reward entries inside a package version Can be fixed rewards or part of a choice group
model RewardPackageLine {
  id                  String   @id @default(uuid()) @db.Uuid
  package_version_id  String   @db.Uuid
  asset_id            String   @db.Uuid
  quantity            Int      @default(1)
  choice_group_id     String?  @db.Uuid
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  package_version     RewardPackageVersion @relation(fields: [package_version_id], references: [id])
  asset               RewardAsset          @relation(fields: [asset_id], references: [id])
  choice_group        RewardChoiceGroup?   @relation(fields: [choice_group_id], references: [id])

  @@map("reward_package_line")
}

// Groups used for user selection logic Example: "Choose 1 out of 3 rewards"
model RewardChoiceGroup {
  id                  String   @id @default(uuid()) @db.Uuid
  package_version_id  String   @db.Uuid
  selection_count     Int      @default(1)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  package_version     RewardPackageVersion @relation(fields: [package_version_id], references: [id])
  options             RewardPackageLine[]

  @@map("reward_choice_group")
}