// Player inventory ledger
model PlayerLedgerEntry {
  id               String   @id @default(uuid()) @db.Uuid
  player_id        String
  asset_id         String   @db.Uuid
  delta            Int
  grant_line_id    String?  @db.Uuid
  reason           String?  @db.VarChar(255)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  asset            RewardAsset      @relation(fields: [asset_id], references: [id])
  grant_line       RewardGrantLine? @relation(fields: [grant_line_id], references: [id])
  player           Player           @relation("PlayerLedgerEntries", fields: [player_id], references: [id])

  @@map("player_ledger_entry")
}